{

  "$schema": "https://railway.app/railway.schema.json",

  "build": {

    "builder": "NIXPACKS",

    "buildCommand": "dotnet publish API/API.csproj -c Release -o /app/publish"

  },

  "deploy": {

    "startCommand": "dotnet /app/publish/API.dll --urls http://*:$PORT",

    "restartPolicyType": "ON_FAILURE",

    "restartPolicyMaxRetries": 10

  }

}